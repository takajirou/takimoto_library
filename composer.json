{
    "name": "takimoto/library",
    "description": "Web学科内の本を管理する小規模な図書貸し出しWebアプリです。",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "pestphp/pest": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "platform": {
            "php": "8.3.31"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
